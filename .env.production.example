# ══════════════════════════════════════════════════════════
# BidToGo — Production Environment Variables
# Copy to .env on your production server
# ══════════════════════════════════════════════════════════

# ---------- Site / Domain ----------
SITE_ADDRESS=bidtogo.ca
NEXTAUTH_URL=https://bidtogo.ca

# ---------- Database ----------
POSTGRES_DB=leadharvest
POSTGRES_USER=leadharvest
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ---------- Auth ----------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# ---------- Admin Account ----------
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ---------- Scraper ----------
# CRITICAL: must be same value for web and scraper containers
# Generate with: openssl rand -hex 16
SCRAPER_API_KEY=CHANGE_ME_RANDOM_KEY
SCRAPER_API_URL=http://scraper-api:8001

# ---------- Crawl Settings ----------
DEFAULT_RATE_LIMIT_SECONDS=3
DEFAULT_USER_AGENT=LeadHarvest/1.0

# ---------- MERX Credentials ----------
MERX_EMAIL=your-merx-email
MERX_PASSWORD=your-merx-password

# ---------- OpenAI ----------
OPENAI_API_KEY=sk-your-key-here

# ---------- AI Cost Control ----------
AI_DAILY_BUDGET_USD=5
AI_MONTHLY_BUDGET_USD=100

# ---------- Logging ----------
LOG_LEVEL=info
